#!/usr/bin/env sh
set -e

echo "🔍 Running pre-commit checks (Native Git Hook)..."

# Find staged files (filters out deleted files) to pass to linters
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|js|svelte|json|md)$' || true)

if [ -n "$STAGED_FILES" ]; then
    # 0. & 1. Format and Lint (Biome)
    # Biome has a native flag to only check staged files, which is lightning fast.
    echo "✨ Formatting & ⚡ Linting (Biome on staged files)..."
    bunx @biomejs/biome check --write --staged

    # Re-stage files in case Biome fixed formatting/linting issues automatically
    git add $STAGED_FILES
else
    echo "⏩ No relevant staged files found for formatting/linting."
fi

# 2. Type Check (Svelte Check)
echo "✅ Type Checking..."
bun run check

# 3. Unit Tests (Fast Bun)
echo "🧪 Testing (Bun Native)..."
bun run test:unit:bun

echo "✨ Pre-commit checks passed!"
